@page
@model WorldDb.Pages.Countries.IndexModel
@{
    ViewData["Title"] = "Countries";
}

<h1>Countries</h1>

@if (Model.Countries.Any())
{
    <table class="table">
        <thead>
            <tr>
                <th>Name</th>
                <th>Capital</th>
                <th>Region</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var country in Model.Countries)
            {
                <tr>
                    <td><a asp-page="Details" asp-route-slug="@country.Slug">@country.Name</a></td>
                    <td>@country.Capital</td>
                    <td>@country.Region</td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p>No countries found.</p>
}
